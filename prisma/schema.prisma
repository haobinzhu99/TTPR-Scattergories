generator client {
  provider            = "prisma-client"
  output              = "TTPR-Scattergories/src/generated/prisma"
  importFileExtension = "js"
  moduleFormat        = "esm"
  runtime             = "nodejs"
}

datasource db {
  provider = "postgresql"
}

model Answer {
  id               String  @id @db.Uuid
  username         String?
  answer           String?
  normalizedAnswer String?
  gameId           BigInt?
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model Game {
  id     String? @db.Uuid
  roomID String?
  letter String?
  topic  String?

  @@ignore
}
