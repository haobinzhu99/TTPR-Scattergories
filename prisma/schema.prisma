generator client {
  provider            = "prisma-client"
  output              = "TTPR-Scattergories/src/generated/prisma"
  importFileExtension = "js"
  moduleFormat        = "esm"
  runtime             = "nodejs"
}

datasource db {
  provider = "postgresql"
}

model answers {
  id         Int      @id @default(autoincrement())
  game_id    Int
  username   String
  answer     String
  created_at DateTime @default(now()) @db.Timestamp(6)
  games      games    @relation(fields: [game_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_answers_game")

  @@unique([game_id, answer], map: "game_answer_unique")
}

model games {
  id         Int       @id @default(autoincrement())
  room_code  String    @unique
  letter     String
  topic      String
  created_at DateTime  @default(now()) @db.Timestamp(6)
  answers    answers[]
}
